rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated and matches the userId
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // User data rule
    match /users/{userId} {
      // Allow read if the requester is the owner by UID OR their email matches the document ID (userId)
      allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == userId);
      // Allow create only if the email matches (initial registration)
      allow create: if request.auth != null && request.auth.token.email == userId;
      // Allow update but prevent role/status tampering from client
      allow update: if (isOwner(userId) || (request.auth != null && request.auth.token.email == userId))
                     && request.resource.data.role == resource.data.role
                     && request.resource.data.status == resource.data.status;
      // Deny delete from client (admin SDK bypasses rules)
      allow delete: if false;

      // Thread subcollection
      match /threads/{threadId} {
        allow read, write: if isOwner(userId);
        
        // Messages subcollection
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Decisions subcollection
      match /decisions/{decisionId} {
        allow read, write: if isOwner(userId);
      }

      // Token Usage subcollection
      match /tokenUsage/{monthId} {
        allow read: if isOwner(userId) || (request.auth != null && request.auth.token.email == userId);
        // Client cannot write directly to tokenUsage, only server-side logic using Admin SDK
        allow write: if false;
      }
    }
    
    // Default deny for all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
